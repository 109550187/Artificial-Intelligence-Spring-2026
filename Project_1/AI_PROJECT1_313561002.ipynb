      "source": [
        "all_video_ids = []\n",
        "\n",
        "for keyword in KEYWORDS:\n",
        "    for order in SEARCH_ORDERS:\n",
        "        try:\n",
        "            ids = search_video_ids(\n",
        "                youtube,\n",
        "                keyword=keyword,\n",
        "                order=order,\n",
        "                max_pages=MAX_PAGES_PER_QUERY,\n",
        "                per_page=VIDEOS_PER_PAGE,\n",
        "                published_after=PUBLISHED_AFTER,\n",
        "            )\n",
        "            all_video_ids.extend(ids)\n",
        "\n",
        "            unique_so_far = len(set(all_video_ids))\n",
        "            print(f\"Unique video IDs so far: {unique_so_far}\")\n",
        "\n",
        "            if unique_so_far >= TARGET_VIDEO_COUNT:\n",
        "                break\n",
        "        except HttpError as e:\n",
        "            print(f\"Error while searching keyword={keyword}, order={order}: {e}\")\n",
        "\n",
        "    if len(set(all_video_ids)) >= TARGET_VIDEO_COUNT:\n",
        "        break\n",
        "\n",
        "# Deduplicate and trim to target size\n",
        "unique_video_ids = list(dict.fromkeys(all_video_ids))[:TARGET_VIDEO_COUNT]\n",
        "print(f\"Total unique video IDs collected: {len(unique_video_ids)}\")\n",
        "all_videos = fetch_video_details(youtube, unique_video_ids)\n",
        "\n",
        "unique = {}\n",
        "for item in all_videos:\n",
        "    vid = item.get(\"id\")\n",
        "    if vid and vid not in unique:\n",
        "        unique[vid] = item\n",
        "\n",
        "all_videos = list(unique.values())\n",
        "print(f\"Total unique videos with full metadata: {len(all_videos)}\")\n",
        "\n",
        "with open(RAW_JSON_PATH, \"w\", encoding=\"utf-8\") as f:\n",
        "    json.dump(all_videos, f, ensure_ascii=False, indent=2)\n",
        "\n",
        "print(f\"Saved raw dataset to: {RAW_JSON_PATH}\")"
      ],
      "id": "xcI-JBrTSL5Y"
