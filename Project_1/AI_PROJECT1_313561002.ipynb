      "source": [
        "## Feature Engineering"
      ],
      "id": "WG1jkcZTSL5Y"
    },
    {
      "cell_type": "code",
      "source": [
        "df = df_raw.copy()\n",
        "\n",
        "df[\"title\"] = df[\"title\"].apply(clean_text)\n",
        "df[\"description\"] = df[\"description\"].apply(clean_text)\n",
        "df[\"channelTitle\"] = df[\"channelTitle\"].apply(clean_text)\n",
        "df[\"defaultLanguage\"] = df[\"defaultLanguage\"].fillna(\"\")\n",
        "\n",
        "# only en videos\n",
        "# df = df[df[\"defaultLanguage\"] == \"en\"].copy()\n",
        "df[\"defaultLanguage\"] = df[\"defaultLanguage\"].fillna(\"\")\n",
        "df[\"defaultAudioLanguage\"] = df[\"defaultAudioLanguage\"].fillna(\"\")\n",
        "\n",
        "df = df[\n",
        "    (df[\"defaultLanguage\"] == \"en\") &\n",
        "    (df[\"defaultAudioLanguage\"].str.contains(\"en\"))\n",
        "].copy()\n",
        "\n",
        "df = df[df[\"duration_seconds\"] >= 61].copy()\n",
        "\n",
        "# basic engineered features\n",
        "df[\"title_length\"] = df[\"title\"].apply(len)\n",
        "df[\"num_tags\"] = df[\"tags\"].apply(lambda x: len(x) if isinstance(x, list) else 0)\n",
        "\n",
        "published_dt = pd.to_datetime(df[\"publishedAt\"], errors=\"coerce\", utc=True)\n",
        "df[\"publish_hour\"] = published_dt.dt.hour\n",
        "df[\"publish_day\"] = published_dt.dt.day_name()\n",
        "\n",
        "df[\"like_ratio\"] = np.where(df[\"viewCount\"] > 0, df[\"likeCount\"] / df[\"viewCount\"], 0.0)\n",
        "df[\"comment_ratio\"] = np.where(df[\"viewCount\"] > 0, df[\"commentCount\"] / df[\"viewCount\"], 0.0)\n",
        "\n",
        "df[\"sentiment_score\"] = df[\"title\"].apply(lambda x: sia.polarity_scores(x)[\"compound\"])\n",
        "df[\"description_length\"] = df[\"description\"].apply(len)\n",
        "\n",
        "df[\"log_viewCount\"] = np.log1p(df[\"viewCount\"])\n",
        "df[\"log_likeCount\"] = np.log1p(df[\"likeCount\"])\n",
        "df[\"log_commentCount\"] = np.log1p(df[\"commentCount\"])\n",
        "\n",
        "df = df.dropna(subset=[\"viewCount\", \"categoryId\", \"duration_seconds\", \"publish_hour\", \"publish_day\"]).copy()\n",
        "\n",
        "# category_thresholds = df.groupby(\"categoryId\")[\"viewCount\"].quantile(0.75).to_dict()\n",
        "# df[\"category_viral_threshold\"] = df[\"categoryId\"].map(category_thresholds)\n",
        "# df[\"viral\"] = (df[\"viewCount\"] >= df[\"category_viral_threshold\"]).astype(int)\n",
        "\n",
        "# print(\"Dataset size after filtering:\", len(df))\n",
        "# print(df[\"viral\"].value_counts())\n",
        "# print(df[[\"defaultLanguage\", \"duration_seconds\"]].head())"
