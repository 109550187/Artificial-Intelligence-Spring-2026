        "pca_results = []\n",
        "\n",
        "for model_name, model in [\n",
        "    (\"DecisionTree\", dt_model),\n",
        "    (\"RandomForest\", rf_model)\n",
        "]:\n",
        "    res_no_pca, _ = evaluate_model(\n",
        "        X_with_sentiment, y, model,\n",
        "        numeric_features_with_sentiment, categorical_features,\n",
        "        use_pca=False, smote=False,\n",
        "        label=f\"{model_name}_no_PCA\"\n",
        "    )\n",
        "    pca_results.append(res_no_pca)\n",
        "\n",
        "    res_pca, _ = evaluate_model(\n",
        "        X_with_sentiment, y, model,\n",
        "        numeric_features_with_sentiment, categorical_features,\n",
        "        use_pca=True, smote=False,\n",
        "        label=f\"{model_name}_with_PCA\"\n",
        "    )\n",
        "    pca_results.append(res_pca)\n",
        "\n",
        "pca_df = pd.DataFrame(pca_results).sort_values(\"f1_mean\", ascending=False)\n",
        "pca_df"
