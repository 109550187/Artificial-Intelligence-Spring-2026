      "source": [
        "smote_results = []\n",
        "\n",
        "for model_name, model in [\n",
        "    (\"DecisionTree\", dt_model),\n",
        "    (\"RandomForest\", rf_model)\n",
        "]:\n",
        "    res_no_smote, _ = evaluate_model(\n",
        "        X_with_sentiment, y, model,\n",
        "        numeric_features_with_sentiment, categorical_features,\n",
        "        use_pca=False, smote=False,\n",
        "        label=f\"{model_name}_no_SMOTE\"\n",
        "    )\n",
        "    smote_results.append(res_no_smote)\n",
        "\n",
        "    res_smote, _ = evaluate_model(\n",
        "        X_with_sentiment, y, model,\n",
        "        numeric_features_with_sentiment, categorical_features,\n",
        "        use_pca=False, smote=True,\n",
        "        label=f\"{model_name}_with_SMOTE\"\n",
        "    )\n",
        "    smote_results.append(res_smote)\n",
        "\n",
        "smote_df = pd.DataFrame(smote_results).sort_values(\"f1_mean\", ascending=False)\n",
        "smote_df"
      ],
      "id": "PdGO1WAMSL5a"
