      "source": [
        "def sample_dataframe_by_fraction(df, fraction, target_col=\"viral\", random_state=42):\n",
        "    sampled_parts = []\n",
        "    for cls, grp in df.groupby(target_col):\n",
        "        sampled_parts.append(grp.sample(frac=fraction, random_state=random_state))\n",
        "    return pd.concat(sampled_parts).sample(frac=1.0, random_state=random_state).reset_index(drop=True)\n",
        "\n",
        "size_results = []\n",
        "\n",
        "for frac in [0.4, 0.7, 1.0]:\n",
        "    df_sub = sample_dataframe_by_fraction(df, frac, target_col=\"viral\")\n",
        "    X_sub = df_sub[feature_cols_with_sentiment].copy()\n",
        "    y_sub = df_sub[target_col].copy()\n",
        "\n",
        "    for model_name, model in [\n",
        "        (\"DecisionTree\", dt_model),\n",
        "        (\"RandomForest\", rf_model)\n",
        "    ]:\n",
        "        res, _ = evaluate_model(\n",
        "            X_sub, y_sub, model,\n",
        "            numeric_features_with_sentiment, categorical_features,\n",
        "            use_pca=False, smote=False,\n",
        "            label=f\"{model_name}_fraction_{frac}\"\n",
        "        )\n",
        "        res[\"fraction\"] = frac\n",
        "        size_results.append(res)\n",
        "\n",
        "size_results_df = pd.DataFrame(size_results).sort_values([\"fraction\", \"f1_mean\"], ascending=[True, False])\n",
        "size_results_df"
      ],
      "id": "VYIA0JUbSL5a"
    },
